    "minimatch": "^10.2.5",
    "openai": "^4.52.2",
    "react": "^18.3.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/diff": "^5.2.1",
    "@types/node": "^20.14.10",
    "@types/react": "^18.3.3",
    "@vitest/coverage-v8": "^4.1.2",
    "typescript": "^5.5.3",
    "vitest": "^4.1.2"
  }

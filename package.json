{
  "name": "claude-code",
  "version": "1.0.0",
  "description": "Clean-room terminal AI agent harness",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "main": "dist/cli/index.js",
  "bin": {
    "claude-code": "dist/cli/index.js"
  },
  "scripts": {
    "build": "tsc --project tsconfig.build.json",
